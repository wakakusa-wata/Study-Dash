{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with study statistics and reward points",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number" },
        "weeklyGoalMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "xp"]
    },
    "Task": {
      "title": "Task",
      "description": "Individual or shared learning assignments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "userId": { "type": "string" },
        "teamId": { "type": "string" },
        "googleCalendarEventId": { "type": "string" },
        "overdueReminded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "userId", "status", "progress", "createdAt", "updatedAt"]
    },
    "Team": {
      "title": "Team",
      "description": "Study groups for collaborative task planning",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "members", "createdAt"]
    },
    "Journal": {
      "title": "Journal",
      "description": "Reflective diary entries of daily studies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "studyMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "studyMinutes", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Weekly or period-defined target settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "startDate", "endDate", "status", "createdAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Regular examination or test dates with subject lists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "examDate": { "type": "string" },
        "subjects": { "type": "array" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "examDate", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile collection"
    },
    "tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks collection"
    },
    "teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Teams collection"
    },
    "journals/{journalId}": {
      "schema": { "$ref": "#/entities/Journal" },
      "description": "Reflection journals collection"
    },
    "goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "Study goals collection"
    },
    "exams/{examId}": {
      "schema": { "$ref": "#/entities/Exam" },
      "description": "Regular test dates and schedule collection"
    }
  }
}
